{
  "name": "skcsai",
  "version": "1.0.0",
  "description": "SKCS AI - Multi-Sport Prediction Platform",
  "main": "backend/server-express.js",
  "scripts": {
    "build:supabase": "esbuild js/supabase-client-src.js --bundle --outfile=public/js/supabase-bundle.js --format=iife --global-name=supabase",
    "start": "node backend/server-express.js",
    "dev": "nodemon backend/server-express.js",
    "sync:live": "node backend/services/syncService.js",
    "test": "node scripts/smoke-test.js",
    "test:smoke": "node scripts/smoke-test.js",
    "refresh:trigger": "node scripts/trigger-refresh.js",
    "refresh:football": "node scripts/trigger-refresh.js --sport=football",
    "grade:trigger": "node scripts/trigger-grade.js",
    "grade:football": "node scripts/trigger-grade.js --sport=football",
    "settlement:trigger": "node scripts/trigger-settlement.js",
    "settlement:football": "node scripts/trigger-settlement.js --sport=football",
    "accuracy:track": "node scripts/track-prediction-accuracy.js",
    "accuracy:april5": "node scripts/track-prediction-accuracy.js --date=2026-04-05 --sport=football",
    "context:backfill": "node scripts/backfill-football-context.js",
    "context:april5": "node scripts/backfill-football-context.js --date=2026-04-05 --sport=football",
    "sync:sportsrc": "node backend/scripts/sync-sportsrc-fixtures.js",
    "cricket:cache:daily": "node scripts/cricapi-cache-refresh.js --mode=daily",
    "cricket:cache:live": "node scripts/cricapi-cache-refresh.js --mode=live"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.105.1",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "moment-timezone": "^0.5.48",
    "morgan": "^1.10.0",
    "node-cron": "^4.2.1",
    "path": "^0.12.7",
    "pg": "^8.13.3",
    "sentiment": "^5.0.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.14"
  }
}
