#!/bin/sh
# Local-only Master Rulebook guard. Runs on your machine; no GitHub Actions billing.

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
NEED_CHECK=0

for file in $STAGED_FILES; do
  case "$file" in
    backend/*|public/js/*|public/subscription.html|SKCS-KNOWLEDGE/*|sql/*|supabase/migrations/*|scripts/*|AGENTS.md|STRICT_RULES.md|SKCS_MASTER_RULEBOOK.md|*.md)
      NEED_CHECK=1
      break
      ;;
  esac
done

if [ "$NEED_CHECK" -eq 0 ]; then
  exit 0
fi

echo "Running Master Rulebook alignment guard..."
npm run verify:rulebook --silent
STATUS=$?

if [ "$STATUS" -ne 0 ]; then
  echo ""
  echo "Commit blocked: legacy rule thresholds detected."
  echo "Fix the reported lines or run: npm run verify:rulebook"
  exit 1
fi

exit 0
