# ─────────────────────────────────────────────
# PIPELINE / ACCA TUNING
# ─────────────────────────────────────────────
ACCA_CONFIDENCE_MIN=55
BOT_ACCA_CONFIDENCE_MIN=60
PHASE_ONE_ACCA_MIN_CONFIDENCE=55
MEGA_ACCA_MIN_LEG_CONFIDENCE=60
PREDICTION_ACCA_WINDOW_LOOKBACK_HOURS=48
PREDICTION_ACCA_STARTED_LOOKBACK_HOURS=2
PREDICTION_UPCOMING_GRACE_MINUTES=90
EDGEMIND_VISIBLE_WINDOW_HOURS=24
LIVE_FETCH_WINDOW_DAYS=3
LIVE_MAX_FIXTURES_PER_SOURCE=50
LIVE_MIN_FIXTURES_TARGET=5
SPORT_FETCH_STAGGER_MS=500
SKCS_STALE_RUN_HOURS=12
ACTIVE_DEPLOYMENT_SPORTS=football,basketball,cricket

# ─────────────────────────────────────────────
# CIRCUIT BREAKER / KEY POOL
# ─────────────────────────────────────────────
PROVIDER_CB_FAILURE_THRESHOLD=3
PROVIDER_CB_COOLDOWN_MS=60000
PROVIDER_CB_MAX_ENTRIES=50
KEY_POOL_MAX_SLOTS=10

# ─────────────────────────────────────────────
# DEBUG FLAGS
# ─────────────────────────────────────────────
DEBUG_AI_SCORING=false
ENABLE_ULTRA_TIER_RULES=false
SKCS_CONTEXT_INSERT_TEST=false
