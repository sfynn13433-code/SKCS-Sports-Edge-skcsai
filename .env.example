# SKCS AI - Sports Edge Platform
# Copy this file to .env and fill in your values.
# All keys marked (required) must be set or the server will not function correctly.

# ─────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=10000
DATA_MODE=live
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false
FRONTEND_ORIGINS=https://skcs.co.za,https://www.skcs.co.za

# ─────────────────────────────────────────────
# DATABASE (required)
# ─────────────────────────────────────────────
DATABASE_URL=your_postgres_connection_string_here
DIRECT_URL=your_direct_postgres_connection_string_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Aliases used in parts of the codebase
SUPABASE_KEY=your_supabase_service_role_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
SERVICE_ROLE_KEY=your_supabase_service_role_key_here
REDIS_URL=

# ─────────────────────────────────────────────
# AUTHENTICATION & SECURITY (required)
# ─────────────────────────────────────────────
JWT_SECRET=replace_with_strong_random_secret
ADMIN_API_KEY=replace_with_admin_key
USER_API_KEY=replace_with_user_key
USER_API_KEYS=
CRON_SECRET=replace_with_strong_cron_secret
ADMIN_BYPASS_EMAIL=
ALLOW_LEGACY_USER_KEY=false
X_AUTH_TOKEN=

# ─────────────────────────────────────────────
# SUBSCRIPTIONS / BILLING
# ─────────────────────────────────────────────
BILLING_ENABLED=false
SUBSCRIPTION_OPEN=true
ALLOW_SELF_SERVE_PLAN_SELECTION=true

# ─────────────────────────────────────────────
# RAPIDAPI (shared key)
# ─────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here
X_RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=
RAPIDAPI_HOSTS_ACTIVE=
RAPIDAPI_HOSTS_ACTIVE_ALL=
RAPIDAPI_HOST_FALLBACK_LIMIT=3
RAPIDAPI_BYPASS_CACHE_WALL=false

# ─────────────────────────────────────────────
# CRICKET PROVIDERS
# ─────────────────────────────────────────────
RAPIDAPI_HOST_CRICBUZZ=cricbuzz-cricket.p.rapidapi.com
RAPIDAPI_HOST_CRICKETAPI3=cricketapi3.p.rapidapi.com
RAPIDAPI_HOST_CRICKET_LIVE_LINE=cricket-live-line1.p.rapidapi.com
RAPIDAPI_CRICKET_LIVE_LINE_KEY=
RAPIDAPI_HOST_CRICKET_LIVE_LINE_ADVANCE=cricket-live-line-advance.p.rapidapi.com
RAPIDAPI_CRICKET_LIVE_LINE_ADVANCE_KEY=
RAPIDAPI_HOST_LIVESCORE6=livescore6.p.rapidapi.com
RAPIDAPI_LIVESCORE6_KEY=
RAPIDAPI_HOST_CRICKET_LIVE=
CRICKETDATA_API_KEY=your_cricketdata_key_here
CRICKET_TZ=Africa/Johannesburg
CRICKET_TRIGGER_TIMEOUT_MS=55000
CRICAPI_FEATURED_LIMIT=5
CRICAPI_LIVE_MAX_MATCHES=6
CRICAPI_DETAIL_DELAY_MS=1000
CRICAPI_SERIES_LIMIT=0
CRICAPI_TRACKED_SERIES_IDS=

# ─────────────────────────────────────────────
# FOOTBALL PROVIDERS
