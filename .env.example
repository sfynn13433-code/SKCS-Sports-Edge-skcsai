# ─────────────────────────────────────────────
RENDER_EXTERNAL_URL=https://skcsai-z8cd.onrender.com
SKCS_TRIGGER_HOST=https://skcsai-z8cd.onrender.com
SKCS_REFRESH_HOST=https://skcsai-z8cd.onrender.com
SKCS_REFRESH_KEY=
TRIGGER_TIMEOUT_MS=55000

# ─────────────────────────────────────────────
# TIER 1 DATA INGESTION
# ─────────────────────────────────────────────
TIER1_HTTP_DELAY_MS=2400
TIER1_MAX_TEAMS_PER_LEAGUE=10
TIER1_MAX_PLAYERS_PER_TEAM=8
