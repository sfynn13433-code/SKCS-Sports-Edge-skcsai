# Sports Data Ingestion Environment Configuration
# Copy this file to .env and fill in your API keys

# RapidAPI Configuration
RAPIDAPI_KEY=your_rapidapi_key_here
X_RAPIDAPI_KEY=your_rapidapi_key_here

# Cricket Providers
RAPIDAPI_HOST_CRICBUZZ=cricbuzz-cricket.p.rapidapi.com
RAPIDAPI_HOST_CRICKETAPI3=cricketapi3.p.rapidapi.com
RAPIDAPI_HOST_CRICKET_LIVE_LINE=cricket-live-line1.p.rapidapi.com
RAPIDAPI_CRICKET_LIVE_LINE_KEY=
RAPIDAPI_HOST_CRICKET_LIVE_LINE_ADVANCE=cricket-live-line-advance.p.rapidapi.com
RAPIDAPI_CRICKET_LIVE_LINE_ADVANCE_KEY=
RAPIDAPI_HOST_LIVESCORE6=livescore6.p.rapidapi.com
RAPIDAPI_LIVESCORE6_KEY=

# Odds API V4 (required for odds integration)
ODDS_API_KEY=your_odds_api_key_here

# Sports provider keys (split by provider)
THESPORTSDB_KEY=your_thesportsdb_key_here
SPORTSDATA_IO_KEY=your_sportsdataio_key_here
# Legacy shared key (backward compatibility only)
SPORTS_DB_KEY=
THESPORTSDB_DELAY_MS=500
TIER1_HTTP_DELAY_MS=2400
TIER1_MAX_TEAMS_PER_LEAGUE=10
TIER1_MAX_PLAYERS_PER_TEAM=8

# Database Configuration
DATABASE_URL=your_database_url_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_KEY=your_supabase_service_role_key_here

# API-Sports Keys (for additional sports data)
# Follow the rotation pattern: API_FOOTBALL_KEY_1, API_FOOTBALL_KEY_2, etc.
X_APISPORTS_KEY=your_primary_apisports_key_here
API_FOOTBALL_KEY_1=your_football_key_1_here
API_FOOTBALL_KEY_2=your_football_key_2_here
API_BASKETBALL_KEY_1=your_basketball_key_1_here
API_NBA_KEY_1=your_nba_key_1_here
API_NFL_KEY_1=your_nfl_key_1_here
API_BASEBALL_KEY_1=your_baseball_key_1_here
API_HOCKEY_KEY_1=your_hockey_key_1_here
API_RUGBY_KEY_1=your_rugby_key_1_here
API_VOLLEYBALL_KEY_1=your_volleyball_key_1_here
API_HANDBALL_KEY_1=your_handball_key_1_here
API_AFL_KEY_1=your_afl_key_1_here
API_FORMULA1_KEY_1=your_formula1_key_1_here
API_MMA_KEY_1=your_mma_key_1_here

# Other API Keys (for future integrations)
RAPIDAPI_KEY=your_rapidapi_key_here
X_RAPIDAPI_KEY=your_x_rapidapi_key_here
NEWSAPI_KEY=your_newsapi_key_here
NEWSAPI_DAILY_CALL_LIMIT=95
CRICKETDATA_API_KEY=your_cricketdata_key_here
CRICKET_TZ=Africa/Johannesburg
CRICAPI_FEATURED_LIMIT=5
CRICAPI_LIVE_MAX_MATCHES=6
CRICAPI_DETAIL_DELAY_MS=1000
CRICAPI_SERIES_LIMIT=0
CRICAPI_TRACKED_SERIES_IDS=

# Logging Configuration
LOG_LEVEL=INFO

# Application Settings
DEBUG=False
ENVIRONMENT=development

# API authentication keys for backend routes
USER_API_KEY=skcs_user_12345
ADMIN_API_KEY=replace_with_admin_key

# Cron job authentication (used by cron-job.org)
CRON_SECRET=skcs_super_secret_cron_key_2026
